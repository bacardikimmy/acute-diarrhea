<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    :root{
      --bg: #f4f7fb;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --line: #e5e7eb;
      --blue1: #123c69;
      --blue2: #1d5f99;

      --green: #198754;
      --green-soft: #eaf7f0;

      --red: #dc3545;
      --red-soft: #fdecee;

      --shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
      --radius-xl: 22px;
      --radius-lg: 18px;
      --radius-md: 14px;
      --radius-sm: 12px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-y:auto;
    }

    .container {
      width: 100%;
      max-width: none;
      margin: 0;
      padding: 14px;
      overflow: visible;
    }

    .header {
      background: linear-gradient(90deg, #123c69 0%, #1d5f99 55%, #3b8fd3 100%);
      color: white;
      border-radius: 18px;
      padding: 18px 32px;
      box-shadow: var(--shadow);
      margin-bottom: 16px;
    }

    .header h1 {
      margin: 0;
      font-size: 34px;
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.4px;
    }

    .header p {
      margin: 12px 0 0 0;
      font-size: 15px;
      line-height: 1.35;
      opacity: 0.95;
    }

    .layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 22px;
      align-items: start;
    }

    .card {
      background: var(--card);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 26px;
      overflow: visible;
    }

    .section-title {
      font-size: 17px;
      font-weight: bold;
      color: var(--blue1);
      margin-bottom: 12px;
    }

    .input-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .field-group label {
      display: block;
      font-weight: bold;
      font-size: 13px;
      margin-bottom: 4px;
      color: #253b5b;
    }

    .field-group input,
    .field-group select {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid #d1d5db;
      border-radius: 9px;
      font-size: 13px;
      background: #fff;
    }

    .field-group input:focus,
    .field-group select:focus {
      outline: none;
      border-color: var(--blue2);
      box-shadow: 0 0 0 3px rgba(29,95,153,0.12);
    }

    .hint {
      font-size: 11px;
      color: #64748b;
      margin-top: 5px;
      line-height: 1.35;
    }

    .btn-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: 12px;
    }

    button {
      border: none;
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 13px;
      font-weight: bold;
      cursor: pointer;
    }

    .btn-primary {
      background: var(--blue1);
      color: #fff;
    }

    .btn-primary:hover {
      background: #0f3255;
    }

    .btn-secondary {
      background: #eef2f7;
      color: #374151;
    }

    .btn-secondary:hover {
      background: #e5ebf3;
    }

    button:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }

    .error {
      display: none;
      margin-top: 14px;
      background: #fef2f2;
      color: #991b1b;
      border-left: 5px solid #dc2626;
      padding: 12px;
      border-radius: 10px;
      line-height: 1.5;
      font-size: 14px;
    }

    .dashboard {
      position: static;
    }

    .dashboard-placeholder {
      border: 1px dashed #cbd5e1;
      background: #f8fafc;
      color: #64748b;
      border-radius: 12px;
      padding: 12px;
      font-size: 13px;
      line-height: 1.4;
    }

    .dashboard-content {
      display: none;
    }

    .risk-panel {
      border-radius: 14px;
      padding: 14px;
      margin-bottom: 10px;
      border: 2px solid transparent;
    }

    .risk-panel.low {
      background: #ecfdf5;
      border-color: #bbf7d0;
    }

    .risk-panel.high {
      background: #fff1f2;
      border-color: #fecdd3;
    }

    .risk-top {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 14px;
      flex-wrap: wrap;
    }

    .risk-title {
      font-size: 16px;
      font-weight: 500;
      color: var(--blue1);
      margin-bottom: 8px;
      line-height: 1.3;
    }

    .risk-number {
      font-size: 52px;
      font-weight: 800;
      line-height: 1;
      letter-spacing: -1px;
    }

    .risk-panel.low .risk-number,
    .risk-panel.low .risk-badge,
    .summary-value.low {
      color: var(--green);
    }

    .risk-panel.high .risk-number,
    .risk-panel.high .risk-badge,
    .summary-value.high {
      color: var(--red);
    }

    .risk-badge {
      display: inline-block;
      font-size: 14px;
      font-weight: bold;
      padding: 7px 12px;
      background: rgba(255,255,255,0.8);
      border-radius: 999px;
    }

    .progress-wrap {
      margin-top: 16px;
    }

    .progress-top {
      display: flex;
      justify-content: space-between;
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .progress-bar {
      height: 13px;
      width: 100%;
      background: #e5e7eb;
      border-radius: 999px;
      overflow: hidden;
      position: relative;
    }

    .progress-fill {
      height: 100%;
      width: 0%;
      border-radius: 999px;
      transition: width 0.4s ease;
    }

    .progress-fill.low {
      background: var(--green);
    }

    .progress-fill.high {
      background: var(--red);
    }

    .cutoff-marker {
      position: relative;
      margin-top: 6px;
      height: 32px;
    }

    .cutoff-line {
      position: absolute;
      left: 15%;
      top: -21px;
      height: 30px;
      width: 3px;
      background:var(--blue1);
      border-radius: 999px;
      z-index: 2;
    }

    .cutoff-label {
      position: absolute;
      left: 15%;
      transform: translateX(-50%);
      top: 10 px;
      font-size: 13px;
      font-weight: 700;
      color: var(--blue1);
      background:  #ffffff;
      padding: 2px 8px;
      border-radius: 7px;
      z-index: 3;
    }

    .recommendation-box {
      background: #f8fafc;
      border-left: 4px solid var(--blue1);
      border-radius: 12px;
      padding: 14px 16px;
      margin-top: 14px;
    }

    .box-title {
      font-size: 17px;
      font-weight: 800;
      color: var(--blue1);
      margin-bottom: 8px;
    }

    .recommendation-text {
      font-size: 15px;
      line-height: 1.6;
      color: #1f2937;
    }

    .disclaimer-title {
      font-size: 12px;
      font-weight: 700;
      color: #64748b;
      margin-bottom: 4px;
    }

    .disclaimer-text {
      font-size: 11px;
      font-weight: 400;
      line-height: 1.45;
      color: #64748b;
    }

    .disclaimer-box {
      background: #f8fafc;
      border-radius: 10px;
      padding: 10px 12px;
      margin-top: 10px;
    }

    .warning {
      display: none;
      background: #fff7ed;
      color: #9a3412;
      border-left: 4px solid #f97316;
      padding: 8px;
      border-radius: 9px;
      margin-top: 8px;
      line-height: 1.35;
      font-size: 11px;
    }

    .error {
      display: none;
      margin-top: 8px;
      background: #fef2f2;
      color: #991b1b;
      border-left: 4px solid #dc2626;
      padding: 8px;
      border-radius: 9px;
      line-height: 1.35;
      font-size: 12px;
    }

    .save-status {
      display: none;
      margin-top: 10px;
      padding: 10px 14px;
      border-radius: 10px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      color: #64748b;
      font-size: 13px;
      font-weight: 400;
      line-height: 1.4;
    }

    @media (max-width: 960px) {
      .container {
        height: auto;
        overflow: visible;
        padding: 10px;
      }

      .layout {
        grid-template-columns: 1fr;
      }

      .card {
        max-height: none;
        overflow: visible;
      }      

      .dashboard {
        position: static;
      }

      .header h1 {
        font-size: 32px;
      }

      .header p {
        font-size: 12px;
      }

      .risk-number {
        font-size: 40px;logo
      }
    }

      .header-content {
        display: flex;
        align-items: center;
        gap: 24px;
        min-height: 95px;
      }

      .logo-badge {
        width: 110px;
        height: 110px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0f3b66 0%, #1d5f99 55%, #4da3d9 100%);
        border: 1.5px solid rgba(255, 255, 255, 0.35);
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);
        flex-shrink: 0;
      }

      .hospital-logo {
        width: 105px;
        height: 105px;
        object-fit: contain;
        display: block;
        flex-shrink: 0;
      }

    @media screen and (max-width: 768px) {
      .container {
          width: 100%;
          max-width: 100%;
          margin: 0;
          padding: 10px;
      }

      .layout {
        display: grid !important;
        grid-template-columns: 1fr !important;
        gap: 16px;
      }
      .card {
        width: 100%;
        max-width: 100%;
        padding: 18px;
        border-radius: 16px;
      }

      .dashboard {
        width: 100%;
        position: static !important;
      }

      .btn-row {
        display: grid !important;
        grid-template-columns: 1fr !important;
        gap: 10px;
      }

      .risk-top {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }     

      .details-grid {
        grid-template-columns: 1fr;
      }

      .header {
        padding: 16px;
        border-radius: 16px;
        margin-bottom: 14px;
      }

      .header-content {
        min-height: auto;
        gap: 12px;
      }

      .header-text {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .logo-badge {
        width: 78px;
        height: 78px;

      }

      .hospital-logo {
        width: 80px;
        height: 80px;
      }

      .header h1 {
        font-size: 24px;
        line-height: 1.2;
      }

        .header p {
        font-size: 12px;
        line-height: 1.35;
      }

      .section-title {
        font-size: 24px;
      }

      .field-group label {
        font-size: 16px;
      }

      .field-group input,
      .field-group select {
        width: 100%;
        font-size: 16px;
        padding: 12px 14px;
      }

      .hint {
        font-size: 13px;
        line-height: 1.45;
      }

      .risk-number {
        font-size: 48px;
      }

      .recommendation-text,
      .disclaimer-box {
        font-size: 15px;
        line-height: 1.6;
      }

      .risk-title {
        font-size: 18px;
        font-weight: 800;
      }

      .box-title {
        font-size: 24px;
        font-weight: bold;
      }
    }
  </style>
</head>

<body>
  <div class="container">

    <div class="header">
      <div class="header-content">
        <img src="https://drive.google.com/thumbnail?id=1P57zRsMYc3vilwKQCvIKsNi6bc2_a9Kn" class="hospital-logo" alt="Hospital logo">
        <div class="header-text">
          <h1>Acute Diarrhea Risk Prediction Tool</h1>
          <p>Prediction of Grade ≥ 2 acute radiation-induced diarrhea (CTCAE Version 5.0)<br>
          in cervical cancer patients treated with concurrent chemoradiotherapy using Helical Tomotherapy</p>
        </div>
       </div>  
     </div>

    <div class="layout">

      <!-- LEFT: INPUT -->
      <div class="card">
        <div class="section-title">Risk Factors</div>

        <div class="input-grid">

          <div class="field-group">
            <label for="bmi">BMI (kg/m²)</label>
            <input type="number" id="bmi" placeholder="Enter BMI" min="10" max="60" step="0.1">
            <div class="hint">
              Enter BMI as a continuous value.<br>
              BMI categories: underweight (<18.5 kg/m²), normal and overweight (18.5–24.9 kg/m²), and obese (≥25.0 kg/m²) <br> 
              (modified Asian criteria; WHO WPRO, 2000).
            </div>
          </div>

          <div class="field-group">
            <label for="dm">Diabetes mellitus</label>
            <select id="dm">
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>

          <div class="field-group">
            <label for="preNAC">Neoadjuvant chemotherapy</label>
            <select id="preNAC">
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>

          <div class="field-group">
            <label for="chemoGroup">Chemotherapy drug type (CCRT)</label>
            <select id="chemoGroup">
              <option value="0">Cisplatin</option>
              <option value="1">Carboplatin</option>
              <option value="2">Combined chemotherapy</option>
            </select>
            <div class="hint">
              Combined chemotherapy refers to multi-agent regimens such as Cisplatin + Carboplatin, Carboplatin + Paclitaxel,<br> 
              or Cisplatin/5-FU + Carboplatin.
            </div>
          </div>

          <div class="field-group">
            <label for="paraaortic">Para-aortic EFRT</label>
            <select id="paraaortic">
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
            <div class="hint">
              Para-aortic EFRT: Para-aortic extended field radiotherapy.
            </div>
          </div>

          <div class="field-group">
            <label for="v45">Bowel bag V<sub>45 Gy</sub> (cc) </label>
            <input type="number" id="v45" placeholder="Enter V45 Gy (cc)" min="0.01" step="0.01">
            <div class="hint">
              Bowel refers to the Bowel Bag structure according to the RTOG pelvic normal tissue contouring guidelines (Gay et al., 2012).
            </div>
          </div>

        </div>

        <div class="btn-row">
          <button type="button" class="btn-primary" id="calculateButton" onclick="predictRisk()">Predict Risk</button>
          <button type="button" class="btn-secondary" onclick="resetForm()">Reset</button>
        </div>

        <div class="error" id="errorBox"></div>
      </div>

      <!-- RIGHT: DASHBOARD -->
      <div class="card dashboard">
        <div class="section-title">Prediction Dashboard</div>

        <div class="dashboard-placeholder" id="resultPlaceholder">
          Fill in the patient and treatment information on the left, then click
          <strong>Predict Risk</strong> to display the prediction dashboard.
        </div>

        <div class="dashboard-content" id="resultContent">

          <div class="risk-panel" id="riskPanel">
            <div class="risk-top">
              <div>
                <div class="risk-title">Predicted probability of Grade ≥ 2 acute diarrhea</div>
                <div class="risk-number" id="riskPercent">--%</div>
                <div style="font-size:14px; color:#6b7280;">
                </div>
              </div>

              <div class="risk-badge" id="riskCategory">--</div>
            </div>

            <div class="progress-wrap">
              <div class="progress-top">
                <span>0%</span>
                <span>100%</span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill" id="progressFill"></div>
              </div>
              <div class="cutoff-marker">
                <div class="cutoff-line"></div>
                <div class="cutoff-label">Cut-off 15%</div>
              </div>
            </div>
          </div>

          <div class="warning" id="warningBox">
            The original log-link prediction exceeded 100% and was capped at 100% for display.
            Please verify input range and model calibration before interpretation.
          </div>

          <div class="recommendation-box">
            <div class="box-title">Clinical Interpretation</div>
            <div class="recommendation-text" id="recommendation">
              --
            </div>
          </div>

          <div id="saveStatus" class="save-status"></div>

          <div class="disclaimer-box">
            <div class="disclaimer-title">Clinical Note</div>
            <div class="disclaimer-text">
              This prediction is intended to support early risk awareness and individualized patient monitoring.
              Clinical judgment should be applied when interpreting the result.
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    function getLogoBase64() {
      const fileId = '1P57zRsMYc3vilwKQCvIKsNi6bc2_a9Kn';
      const blob = DriveApp.getFileById(fileId).getBlob();
      const contentType = blob.getContentType();
      const base64 = Utilities.base64Encode(blob.getBytes());

      return 'data:' + contentType + ';base64,' + base64;
    }

    function predictRisk() {
      clearError();

      const button = document.getElementById('calculateButton');
      button.disabled = true;
      button.innerText = 'Predicting...';

      const bmiValue = document.getElementById('bmi').value;
      const v45Value = document.getElementById('v45').value;

      if (bmiValue === '') {
        showError('Please enter BMI.');
        button.disabled = false;
        button.innerText = 'Predict Risk';
        return;
      }

      if (v45Value === '') {
        showError('Please enter Bowel V45Gy.');
        button.disabled = false;
        button.innerText = 'Predict Risk';
        return;
      }

      const data = {
        bmi: bmiValue,
        dm: document.getElementById('dm').value,
        preNAC: document.getElementById('preNAC').value,
        chemoGroup: document.getElementById('chemoGroup').value,
        paraaortic: document.getElementById('paraaortic').value,
        v45: v45Value
      };

      google.script.run
        .withSuccessHandler(function(result) {
          try {
            showResult(result);
          } catch (e) {
            showError(e.message);
          } finally {
            button.disabled = false;
            button.innerText = 'Predict Risk';
          }
        })
        .withFailureHandler(function(error) {
          showError(error.message || error);
          button.disabled = false;
          button.innerText = 'Predict Risk';
        })
        .calculateRisk(data);
    }

    function showResult(result) {
      document.getElementById('resultPlaceholder').style.display = 'none';
      document.getElementById('resultContent').style.display = 'block';

      const riskPercent = parseFloat(result.riskPercent);
      const category = result.category;
      const isHigh = category === 'High risk';

      const riskPanel = document.getElementById('riskPanel');
      const riskNumber = document.getElementById('riskPercent');
      const riskCategory = document.getElementById('riskCategory');
      const progressFill = document.getElementById('progressFill');
      const recommendation = document.getElementById('recommendation');
      const warningBox = document.getElementById('warningBox');

      riskPanel.classList.remove('low', 'high');
      progressFill.classList.remove('low', 'high');

      if (isHigh) {
        riskPanel.classList.add('high');
        progressFill.classList.add('high');
      } else {
        riskPanel.classList.add('low');
        progressFill.classList.add('low');
      }

      riskNumber.innerText = result.riskPercent + '%';
      riskCategory.innerText = category;

      let progressPercent = Math.min(riskPercent, 100);
      progressFill.style.width = progressPercent + '%';

      if (isHigh) {
        recommendation.innerHTML =
          '<strong>High-risk interpretation:</strong><br>' +
          'Consider close monitoring during radiotherapy, early dietary counseling, hydration management, ' +
          'and proactive supportive care.';
      } else {
        recommendation.innerHTML =
          '<strong>Low-risk interpretation:</strong><br>' +
          'Routine monitoring may be appropriate, while clinical judgment should still be applied.';
      }

      if (Number(result.originalRisk) > 1) {
        warningBox.style.display = 'block';
      } else {
        warningBox.style.display = 'none';
      }

      const saveStatus = document.getElementById('saveStatus');

      if (result.saved) {
        if (result.saved) {
          saveStatus.innerText = 'Record saved to Google Sheet.';
          saveStatus.style.display = 'block';
        } else {
          saveStatus.innerText = '';
          saveStatus.style.display = 'none';
        }
      } 

      if (window.innerWidth <= 768) {
        document.getElementById('resultContent').scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    }
  
    function resetForm() {
      document.getElementById('bmi').value = '';
      document.getElementById('dm').value = '0';
      document.getElementById('preNAC').value = '0';
      document.getElementById('chemoGroup').value = '0';
      document.getElementById('paraaortic').value = '0';
      document.getElementById('v45').value = '';

      clearError();

      document.getElementById('resultPlaceholder').style.display = 'block';
      document.getElementById('resultContent').style.display = 'none';
      
      const saveStatus = document.getElementById('saveStatus');
      if (saveStatus) {
        saveStatus.innerText = '';
        saveStatus.style.display = 'none';
      }
    }

    function showError(message) {
      const errorBox = document.getElementById('errorBox');
      errorBox.innerText = message;
      errorBox.style.display = 'block';
    }

    function clearError() {
      const errorBox = document.getElementById('errorBox');
      errorBox.innerText = '';
      errorBox.style.display = 'none';
    }
  </script>
</body>
</html>
